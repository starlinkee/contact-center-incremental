<% const title = 'Dashboard' %>
<%- include('header', { title }) %>

<h1 class="text-2xl font-bold mb-6">Dashboard</h1>

<!-- Stats Grid -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
    <div class="text-sm text-gray-400">Total Businesses</div>
    <div class="text-2xl font-bold text-white"><%= stats.totalBusinesses %></div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
    <div class="text-sm text-gray-400">Emails Found</div>
    <div class="text-2xl font-bold text-green-400"><%= stats.emailsFound %></div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
    <div class="text-sm text-gray-400">Emails Sent</div>
    <div class="text-2xl font-bold text-blue-400"><%= stats.totalSent %></div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
    <div class="text-sm text-gray-400">Open Rate</div>
    <div class="text-2xl font-bold text-yellow-400"><%= stats.openRate %>%</div>
  </div>
</div>

<!-- Today's Usage -->
<div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-8">
  <h2 class="text-lg font-semibold mb-4">Today's Usage</h2>
  <div class="grid grid-cols-3 gap-4">
    <div>
      <div class="text-sm text-gray-400">API Calls</div>
      <div class="text-xl font-bold"><%= todayUsage.places_api_calls %></div>
    </div>
    <div>
      <div class="text-sm text-gray-400">API Cost</div>
      <div class="text-xl font-bold">$<%= todayUsage.places_api_cost.toFixed(2) %></div>
    </div>
    <div>
      <div class="text-sm text-gray-400">Emails Sent</div>
      <div class="text-xl font-bold"><%= todayUsage.emails_sent %></div>
    </div>
  </div>
</div>

<!-- Job Queue Status -->
<div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-8">
  <h2 class="text-lg font-semibold mb-4">Job Queue</h2>
  <div class="flex gap-4">
    <% for (const js of jobStats) { %>
      <div class="px-3 py-1 rounded text-sm
        <% if (js.status === 'pending') { %>bg-yellow-900/50 text-yellow-300<% } %>
        <% if (js.status === 'running') { %>bg-blue-900/50 text-blue-300<% } %>
        <% if (js.status === 'done') { %>bg-green-900/50 text-green-300<% } %>
        <% if (js.status === 'failed') { %>bg-red-900/50 text-red-300<% } %>
      ">
        <%= js.status %>: <%= js.count %>
      </div>
    <% } %>
    <% if (jobStats.length === 0) { %>
      <span class="text-gray-500 text-sm">No jobs in queue</span>
    <% } %>
  </div>
</div>

<!-- Warmup Controls -->
<div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
  <h2 class="text-lg font-semibold mb-4">Warmup Controls</h2>
  <div class="flex gap-3">
    <form method="POST" action="/warmup/check">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm px-4 py-2 rounded transition">
        Check Level-Ups
      </button>
    </form>
    <form method="POST" action="/warmup/reset">
      <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-white text-sm px-4 py-2 rounded transition">
        Reset Daily Counts
      </button>
    </form>
  </div>
</div>

<%- include('footer') %>
